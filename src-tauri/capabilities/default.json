{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*:*/*" },
        { "url": "https://*" },
        { "url": "http://localhost:*/*" },
        { "url": "http://localhost" },
        { "url": "http://127.0.0.1:*/*" },
        { "url": "http://127.0.0.1" },
        { "url": "http://[\\:\\:1]:*/*" },
        { "url": "http://[\\:\\:1]" }
      ]
    },
    "dialog:default",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$APPDATA/**/.nesso" },
        { "path": "$APPDATA/**/.nesso/**" },
        { "path": "$APPLOCALDATA/**/.nesso" },
        { "path": "$APPLOCALDATA/**/.nesso/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$APPDATA/**/.nesso" },
        { "path": "$APPDATA/**/.nesso/**" },
        { "path": "$APPLOCALDATA/**/.nesso" },
        { "path": "$APPLOCALDATA/**/.nesso/**" }
      ]
    },
    {
      "identifier": "fs:allow-stat",
      "allow": [
        { "path": "$APPDATA/**/.nesso" },
        { "path": "$APPDATA/**/.nesso/**" },
        { "path": "$APPLOCALDATA/**/.nesso" },
        { "path": "$APPLOCALDATA/**/.nesso/**" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$APPDATA/**/.nesso" },
        { "path": "$APPDATA/**/.nesso/**" },
        { "path": "$APPLOCALDATA/**/.nesso" },
        { "path": "$APPLOCALDATA/**/.nesso/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$APPDATA/**/.nesso" },
        { "path": "$APPDATA/**/.nesso/**" },
        { "path": "$APPLOCALDATA/**/.nesso" },
        { "path": "$APPLOCALDATA/**/.nesso/**" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$APPDATA/**/.nesso" },
        { "path": "$APPDATA/**/.nesso/**" },
        { "path": "$APPLOCALDATA/**/.nesso" },
        { "path": "$APPLOCALDATA/**/.nesso/**" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$APPDATA/**/.nesso" },
        { "path": "$APPDATA/**/.nesso/**" },
        { "path": "$APPLOCALDATA/**/.nesso" },
        { "path": "$APPLOCALDATA/**/.nesso/**" }
      ]
    },
    {
      "identifier": "fs:allow-rename",
      "allow": [
        { "path": "$APPDATA/**/.nesso" },
        { "path": "$APPDATA/**/.nesso/**" },
        { "path": "$APPLOCALDATA/**/.nesso" },
        { "path": "$APPLOCALDATA/**/.nesso/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$APPDATA/**/.nesso" },
        { "path": "$APPDATA/**/.nesso/**" },
        { "path": "$APPLOCALDATA/**/.nesso" },
        { "path": "$APPLOCALDATA/**/.nesso/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$APPDATA/**/.nesso" },
        { "path": "$APPDATA/**/.nesso/**" },
        { "path": "$APPLOCALDATA/**/.nesso" },
        { "path": "$APPLOCALDATA/**/.nesso/**" }
      ]
    },
    "fs:allow-watch",
    "fs:allow-unwatch",
    {
      "identifier": "fs:scope",
      "allow": [
        "$APPDATA/**/.nesso",
        "$APPDATA/**/.nesso/**",
        "$APPLOCALDATA/**/.nesso",
        "$APPLOCALDATA/**/.nesso/**"
      ]
    },
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    "mcp-bridge:default",
    "updater:default",
    "process:default"
  ]
}
