{
  "name": "@nesso-how/mcp",
  "version": "0.1.0-alpha.32",
  "description": "MCP server exposing Nesso knowledge graph tools to LLM clients",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nesso-how/nesso",
    "directory": "packages/mcp"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "bin": {
    "nesso-mcp": "dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "bundle-docs": "node scripts/bundle-starlight-docs.mjs",
    "build": "rm -rf dist && tsc && node scripts/bundle-starlight-docs.mjs",
    "prepublishOnly": "pnpm build",
    "dev": "tsc --watch",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "zod": "^4.4.3",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "@nesso-how/relation-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "~5.8.3"
  }
}
