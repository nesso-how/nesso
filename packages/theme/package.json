      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "prepublishOnly": "pnpm build",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@nesso-how/relation-types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "~5.8.3"
  }
