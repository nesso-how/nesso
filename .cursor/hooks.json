{
  "version": 1,
  "hooks": {
    "sessionStart": [{ "command": "bash .hooks/session-start.sh cursor" }],
    "beforeShellExecution": [{ "command": "bash .hooks/block-pnpm.sh" }],
    "postToolUse": [
      {
        "command": "bash .hooks/docs-mcp-reminder.sh",
        "matcher": "Write|Edit"
      }
    ]
  }
}
