{
  "name": "nesso",
  "private": true,
  "version": "0.1.0-alpha.25",
  "license": "MIT",
  "packageManager": "pnpm@10.14.0",
  "type": "module",
  "scripts": {
    "license-headers": "node scripts/license-header.mjs",
    "license-headers:check": "node scripts/license-header.mjs --check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint-staged": "lint-staged",
    "build:relation-types": "pnpm --filter @nesso-how/relation-types build",
    "build:types": "pnpm --filter @nesso-how/types build",
    "build:formats": "pnpm --filter @nesso-how/formats build",
    "prepare": "husky && pnpm run build:relation-types && pnpm run build:types && pnpm run build:formats",
    "dev": "vite",
    "build": "pnpm run build:relation-types && pnpm run build:types && pnpm run build:formats && tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "icons:desktop": "tauri icon public/icon/nesso-tile-paper.svg",
    "dev:desktop": "pnpm run icons:desktop && tauri dev",
    "build:desktop": "pnpm run icons:desktop && tauri build"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.83",
    "@nesso-how/formats": "workspace:*",
    "@nesso-how/relation-types": "workspace:*",
    "@nesso-how/types": "workspace:*",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xyflow/react": "^12.6.4",
    "html-to-image": "^1.11.13",
    "idb": "^8.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-fsrs": "^5.3.2",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tauri-apps/cli": "^2.11.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.6.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^6.3.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "prettier --write",
      "eslint --fix",
      "node scripts/license-header.mjs"
    ],
    "*.{json,md,yml,yaml}": "prettier --write",
    "*.{css,html}": [
      "prettier --write",
      "node scripts/license-header.mjs"
    ],
    "*.rs": "node scripts/license-header.mjs"
  }
}
