{
  "name": "nesso",
  "private": true,
  "version": "0.1.0-alpha.33",
  "license": "MIT",
  "packageManager": "pnpm@10.14.0",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
  },
  "type": "module",
  "scripts": {
    "license-headers": "node scripts/license-header.mjs",
    "license-headers:check": "node scripts/license-header.mjs --check",
    "format": "biome format --write . && prettier --write \"**/*.{md,yml,yaml,html}\"",
    "format:check": "biome format . && prettier --check \"**/*.{md,yml,yaml,html}\"",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "analyze": "fallow",
    "analyze:dead-code": "fallow dead-code --fail-on-issues",
    "analyze:dupes": "fallow dupes --baseline fallow-baselines/dupes.json --fail-on-issues",
    "analyze:health": "fallow health --baseline fallow-baselines/health.json --fail-on-issues",
    "analyze:mutation": "pnpm run analyze:mutation:formats && pnpm run analyze:mutation:types && pnpm run analyze:mutation:store && pnpm run analyze:mutation:workspace && pnpm run analyze:mutation:mentor",
    "analyze:mutation:formats": "stryker run stryker.formats.mjs",
    "analyze:mutation:types": "stryker run stryker.types.mjs",
    "analyze:mutation:store": "stryker run stryker.store.mjs",
    "analyze:mutation:workspace": "stryker run stryker.workspace.mjs",
    "analyze:mutation:mentor": "stryker run stryker.mentor.mjs",
    "lint-staged": "lint-staged",
    "release": "node scripts/release.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "type-coverage": "type-coverage -p tsconfig.app.json --strict --at-least 99",
    "build:relation-types": "pnpm --filter @nesso-how/relation-types build",
    "build:types": "pnpm --filter @nesso-how/types build",
    "build:theme": "pnpm --filter @nesso-how/theme build",
    "build:formats": "pnpm --filter @nesso-how/formats build",
    "build:graph": "pnpm --filter @nesso-how/graph build",
    "build:mcp": "pnpm --filter @nesso-how/mcp build",
    "prepare": "husky && pnpm run build:relation-types && pnpm run build:types && pnpm run build:theme && pnpm run build:formats && pnpm run build:graph",
    "dev": "vite",
    "build": "pnpm run build:relation-types && pnpm run build:types && pnpm run build:theme && pnpm run build:formats && pnpm run build:graph && tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "icons:desktop": "tauri icon public/icon/nesso-tile-paper.svg",
    "dev:desktop": "pnpm run icons:desktop && tauri dev",
    "build:desktop": "pnpm run icons:desktop && tauri build"
  },
  "dependencies": {
    "@nesso-how/formats": "workspace:*",
    "@nesso-how/graph": "workspace:*",
    "@nesso-how/relation-types": "workspace:*",
    "@nesso-how/theme": "workspace:*",
    "@nesso-how/types": "workspace:*",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xyflow/react": "^12.6.4",
    "html-to-image": "^1.11.13",
    "idb": "^8.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-fsrs": "^5.3.2",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@playwright/test": "^1.61.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tauri-apps/cli": "^2.11.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.8",
    "fake-indexeddb": "^6.2.5",
    "fallow": "2.98.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.6.2",
    "type-coverage": "^2.29.7",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,css}": [
      "biome check --write --no-errors-on-unmatched",
      "node scripts/license-header.mjs"
    ],
    "*.json": "biome check --write --no-errors-on-unmatched",
    "*.{md,yml,yaml}": "prettier --write",
    "*.html": ["prettier --write", "node scripts/license-header.mjs"],
    "*.rs": "node scripts/license-header.mjs"
  }
}
