{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  // Exports referenced within their own file are intentional, not dead surface.
  "ignoreExportsUsedInFile": true,
  // Test fakes loaded dynamically via vi.mock(async () => (await import(...))) —
  // syntactic analysis cannot see imports inside the mock factory.
  "dynamicallyLoaded": ["src/test/fakeTauriFs.ts"],
  // sharp is Astro's image-optimization dependency: used implicitly, never imported.
  // @playwright/test is consumed only by the e2e specs + config, which are
  // ignored below (run by the Playwright CLI, not imported by app code).
  // @stryker-mutator/vitest-runner is a Stryker plugin loaded by name (a string in
  // `plugins`, stryker.base.mjs), so it is referenced but never imported.
  "ignoreDependencies": ["sharp", "@playwright/test", "@stryker-mutator/vitest-runner"],
  // Theme CSS is generated at build time by the nessoTheme Vite plugin.
  "ignoreUnresolvedImports": ["**/*.generated.css"],
  // Referenced via docs/astro.config.mjs (Starlight `components` override and
  // `customCss`), which fallow does not parse as entry points. The e2e specs and
  // Playwright config are run by the Playwright CLI, not reachable from any app
  // entry point, so they are not dead surface.
  "ignorePatterns": [
    "docs/src/components/ThemeSelect.astro",
    "docs/src/styles/custom.css",
    "e2e/**",
    "playwright.config.ts"
  ]
}
