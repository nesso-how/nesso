---
import type { Locale } from "../i18n/types";

interface Props {
  t: Locale;
  lang: "en" | "it";
  releaseTag: string;
  releaseUrl: string;
}

const { t, lang, releaseTag, releaseUrl } = Astro.props;
const homeHref = lang === "en" ? "/" : `/${lang}/`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{t.meta.title}</title>
    <meta name="description" content={t.meta.description} />
    <link rel="icon" type="image/svg+xml" href="/icon/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500;1,9..144,600&family=JetBrains+Mono:wght@400;500&family=Inter:wght@400;450;500;600&display=swap"
      rel="stylesheet"
    />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --paper: #fcf9f3;
        --paper-deep: #f2ede3;
        --paper-elev: #fffdf7;
        --bg-elev: #fffdf7;
        --bg-card: #fffdf7;
        --ink: #1a1814;
        --ink-2: #3c3830;
        --ink-3: #6a6356;
        --ink-4: #9a9080;
        --ink-5: #c4b9a4;
        --line: rgba(26, 24, 20, 0.1);
        --line-strong: rgba(26, 24, 20, 0.2);
        --grid-dot: rgba(26, 24, 20, 0.18);

        --cat-taxonomic: #2f5d8e;
        --cat-structural: #6b4a8a;
        --cat-causal: #b14a2e;
        --cat-dependency: #8a6a1a;
        --cat-temporal: #2d6a55;
        --cat-opposition: #8a2e4a;
        --cat-similarity: #2a6878;
        --cat-epistemic: #3a4a8a;

        --conf-1: #b14a4a;
        --conf-2: #c47a3a;
        --conf-3: #b89a3a;
        --conf-4: #75752d;

        --accent: var(--ink);
        --highlight: #6e2730;
        --highlight-soft: rgba(110, 39, 48, 0.08);
        --highlight-selection: rgba(110, 39, 48, 0.22);

        --font-serif: "Fraunces", Georgia, serif;
        --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
        --font-mono: "JetBrains Mono", ui-monospace, monospace;

        --shadow-paper:
          0 8px 28px -10px rgba(26, 24, 20, 0.18),
          0 2px 8px rgba(26, 24, 20, 0.06);
        --shadow-lift:
          0 28px 60px -16px rgba(26, 24, 20, 0.22),
          0 8px 20px -8px rgba(26, 24, 20, 0.1);
      }

      html,
      body {
        background: var(--bg-elev);
        color: var(--ink);
        font-family: var(--font-sans);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        font-feature-settings: "ss01", "cv11";
      }

      body {
        position: relative;
        min-height: 100vh;
        overflow-x: hidden;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 1;
        background-image:
          radial-gradient(
            circle at 20% 30%,
            rgba(0, 0, 0, 0.025) 0%,
            transparent 40%
          ),
          radial-gradient(
            circle at 80% 70%,
            rgba(0, 0, 0, 0.02) 0%,
            transparent 40%
          );
        mix-blend-mode: multiply;
        opacity: 0.25;
      }

      main,
      header,
      footer {
        position: relative;
        z-index: 2;
      }

      a {
        color: inherit;
        text-decoration: none;
        transition: color 0.2s;
      }

      ::selection {
        background: var(--highlight-selection);
        color: var(--ink);
      }

      /* ── Header ─────────────────────────────── */
      header {
        max-width: 1080px;
        margin: 0 auto;
        padding: 1.75rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        color: var(--ink);
      }

      .brand-mark {
        width: 28px;
        height: 28px;
        display: block;
      }

      .brand-name {
        font-family: var(--font-serif);
        font-weight: 600;
        font-size: 1.25rem;
        letter-spacing: -0.01em;
        font-optical-sizing: auto;
      }

      .header-nav {
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }

      .header-nav a {
        font-size: 0.875rem;
        color: var(--ink-3);
      }
      .header-nav a:hover {
        color: var(--ink);
      }

      /* ── Hero ──────────────────────────────── */
      .hero {
        max-width: 900px;
        margin: 4rem auto 4rem;
        padding: 0 2rem;
        text-align: center;
      }

      .hero-meta {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.65rem;
        margin-bottom: 1.5rem;
      }

      .hero-release {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        font-weight: 500;
        letter-spacing: 0.06em;
        color: var(--ink-4);
        padding: 0.2rem 0.55rem;
        border-radius: 999px;
        border: 0.5px solid var(--line-strong);
        background: rgba(255, 253, 247, 0.55);
        transition: all 0.2s;
        white-space: nowrap;
      }

      .hero-release:hover {
        color: var(--highlight);
        border-color: color-mix(in srgb, var(--highlight) 45%, transparent);
      }

      .hero-eyebrow {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--ink-3);
        padding-bottom: 0.5rem;
        position: relative;
        white-space: nowrap;
      }

      .hero-eyebrow::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 28px;
        height: 1px;
        background: var(--highlight);
      }

      .hero h1 {
        font-family: var(--font-serif);
        font-weight: 500;
        font-size: clamp(2.25rem, 6vw, 4.75rem);
        line-height: 1.08;
        letter-spacing: -0.025em;
        font-optical-sizing: auto;
        color: var(--ink);
        margin-bottom: 1.5rem;
      }

      .hero h1 em {
        font-style: italic;
        font-weight: 400;
        color: var(--highlight);
      }

      .hero-sub {
        font-size: 1.1rem;
        color: var(--ink-2);
        max-width: 540px;
        margin: 0 auto 1rem;
        line-height: 1.6;
      }

      .hero-sub :global(em) {
        font-style: italic;
        color: var(--highlight);
      }

      .hero-tagline {
        font-family: var(--font-serif);
        font-style: italic;
        font-weight: 500;
        font-size: 1.35rem;
        color: var(--ink);
        margin: 0 auto 2.25rem;
        font-optical-sizing: auto;
      }

      .cta-row {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        justify-content: center;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.7rem 1.35rem;
        border-radius: 8px;
        font-family: var(--font-sans);
        font-size: 0.92rem;
        font-weight: 500;
        transition: all 0.18s;
        cursor: pointer;
        border: none;
      }

      .btn-primary {
        background: var(--ink);
        color: var(--paper);
        box-shadow: var(--shadow-paper);
      }

      .btn-primary:hover {
        background: var(--highlight);
        transform: translateY(-1px);
      }

      .btn-secondary {
        background: transparent;
        color: var(--ink-2);
        border: 1px solid var(--line-strong);
      }

      .btn-secondary:hover {
        color: var(--ink);
        border-color: var(--ink-3);
      }

      .btn-arrow {
        display: inline-block;
        transition: transform 0.2s;
      }
      .btn:hover .btn-arrow {
        transform: translateX(2px);
      }

      /* ── Hero Graph (real Nesso canvas look) ─── */
      .hero-graph-wrap {
        max-width: 820px;
        margin: 5rem auto 0;
        padding: 0 1rem;
      }

      .hero-graph-frame {
        position: relative;
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 14px;
        overflow: hidden;
        box-shadow: var(--shadow-paper);
      }

      .hero-graph-frame::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image: radial-gradient(
          circle,
          var(--grid-dot) 1px,
          transparent 1.2px
        );
        background-size: 22px 22px;
        background-position: 11px 11px;
        pointer-events: none;
        mask-image: linear-gradient(
          to bottom,
          transparent 0%,
          #000 8%,
          #000 92%,
          transparent 100%
        );
        z-index: 0;
      }

      .hero-graph-svg {
        display: block;
        width: 100%;
        height: auto;
        position: relative;
        z-index: 1;
      }

      .hero-graph-socrates {
        position: absolute;
        right: 18px;
        bottom: 18px;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: var(--bg-elev);
        border: 0.5px solid var(--line);
        box-shadow: var(--shadow-paper);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2;
      }

      .hero-graph-socrates::before {
        content: "";
        position: absolute;
        inset: -3px;
        border-radius: 50%;
        border: 1px dashed var(--highlight);
        opacity: 0.4;
        animation: socratesIdleSpin 28s linear infinite;
        pointer-events: none;
      }

      @keyframes socratesIdleSpin {
        to {
          transform: rotate(360deg);
        }
      }

      .hero-graph-meta {
        position: absolute;
        left: 18px;
        top: 18px;
        z-index: 2;
        display: flex;
        gap: 0.5rem;
        align-items: center;
        font-family: var(--font-mono);
        font-size: 0.62rem;
        color: var(--ink-4);
        letter-spacing: 0.12em;
        text-transform: uppercase;
        background: rgba(252, 249, 243, 0.7);
        backdrop-filter: blur(4px);
        padding: 0.3rem 0.6rem;
        border-radius: 4px;
        border: 0.5px solid var(--line);
      }

      .hero-graph-meta .sep {
        opacity: 0.4;
      }

      .ng-node-text {
        font-family: "Fraunces", Georgia, serif;
        font-weight: 500;
        font-size: 17px;
        letter-spacing: -0.005em;
        fill: var(--ink);
        text-anchor: middle;
        font-optical-sizing: auto;
      }

      .ng-node-text-sm {
        font-family: "Fraunces", Georgia, serif;
        font-weight: 500;
        font-size: 15px;
        letter-spacing: -0.005em;
        fill: var(--ink);
        text-anchor: middle;
        font-optical-sizing: auto;
      }

      .ng-node-underline {
        stroke: var(--ink);
        stroke-width: 0.8;
        opacity: 0.55;
      }

      .ng-node-underline-hub {
        stroke: var(--ink);
        stroke-width: 1.2;
        opacity: 0.7;
      }

      .ng-edge-label-text {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 9.5px;
        font-weight: 500;
        letter-spacing: 0.02em;
        text-anchor: middle;
      }

      /* ── Shared section layout ──────────────── */
      .section {
        max-width: 900px;
        margin: 6rem auto;
        padding: 0 2rem;
      }

      .section-label {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--ink-3);
        margin-bottom: 2.5rem;
      }

      .section-label::before,
      .section-label::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--line);
      }

      /* ── Principles (4, with right-side visual) ── */
      .principles {
        display: grid;
        gap: 3.5rem;
      }

      .principle {
        display: grid;
        grid-template-columns: 48px 1fr 240px;
        gap: 1.5rem;
        align-items: start;
      }

      .principle-marker {
        padding-top: 0.45rem;
        font-family: var(--font-mono);
        font-size: 0.78rem;
        color: var(--ink-4);
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .principle-marker .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--highlight);
        flex-shrink: 0;
      }

      .principle-body h3 {
        font-family: var(--font-serif);
        font-weight: 500;
        font-size: 1.55rem;
        letter-spacing: -0.01em;
        color: var(--ink);
        margin-bottom: 0.55rem;
        font-optical-sizing: auto;
      }

      .principle-body p {
        color: var(--ink-2);
        font-size: 1rem;
        line-height: 1.65;
      }

      .principle-body :global(p em) {
        font-style: italic;
        color: var(--highlight);
      }

      .principle-visual {
        align-self: start;
        padding-top: 0.2rem;
      }

      .principle-visual .pv-picker,
      .principle-visual .pv-review,
      .principle-visual .pv-aimode,
      .principle-visual .pv-module {
        box-shadow: var(--shadow-paper);
      }

      /* P1: Chat panel */
      .pv-chat {
        background: linear-gradient(180deg, var(--bg-card), var(--bg-elev));
        border: 0.5px solid var(--line);
        border-radius: 16px;
        box-shadow: var(--shadow-paper);
        display: flex;
        flex-direction: column;
      }

      .pv-chat-header {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.65rem 0.75rem 0.55rem;
        border-bottom: 0.5px solid var(--line);
      }

      .pv-chat-avatar {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: var(--paper-deep);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      .pv-chat-id {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 1px;
      }

      .pv-chat-name {
        font-family: var(--font-serif);
        font-weight: 500;
        font-size: 12.5px;
        letter-spacing: -0.005em;
        color: var(--ink);
      }

      .pv-chat-model {
        font-family: var(--font-mono);
        font-size: 9px;
        color: var(--ink-4);
        letter-spacing: 0.02em;
      }

      .pv-chat-icons {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        color: var(--ink-4);
      }

      .pv-chat-icons svg {
        display: block;
      }

      .pv-chat-body {
        padding: 0.7rem 0.85rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .pv-chat-user-row {
        display: flex;
        justify-content: flex-end;
      }

      .pv-chat-user {
        font-family: var(--font-sans);
        font-weight: 500;
        font-size: 11.5px;
        line-height: 1.45;
        color: var(--ink-2);
        background: var(--paper-deep);
        border: 0.5px solid var(--line);
        border-radius: 12px 12px 4px 12px;
        padding: 5px 9px;
        max-width: 86%;
      }

      .pv-chat-mentor {
        font-family: var(--font-serif);
        font-weight: 400;
        font-size: 13px;
        line-height: 1.45;
        letter-spacing: -0.005em;
        color: var(--ink);
        font-optical-sizing: auto;
      }

      .pv-chat-mentor :global(em) {
        font-style: italic;
        color: var(--ink);
      }

      .pv-chat-input {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.5rem 0.5rem 0.5rem 0.85rem;
        border-top: 0.5px solid var(--line);
        color: var(--ink-4);
        font-family: var(--font-sans);
        font-size: 11.5px;
      }

      .pv-chat-placeholder {
        flex: 1;
      }

      .pv-chat-send {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: var(--ink);
        color: var(--paper);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        opacity: 0.3;
      }

      /* P2: Modules list */
      .pv-modules {
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
      }

      .pv-module {
        background: var(--paper-elev);
        border: 0.5px solid var(--line);
        border-radius: 8px;
        padding: 0.55rem 0.7rem;
        display: flex;
        align-items: center;
        gap: 0.55rem;
        transition: all 0.15s;
      }

      .pv-module:hover {
        border-color: var(--line-strong);
        transform: translateX(2px);
      }

      .pv-module-body {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 1px;
        min-width: 0;
      }

      .pv-module-name {
        font-family: var(--font-mono);
        font-size: 11px;
        font-weight: 500;
        color: var(--ink);
        letter-spacing: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .pv-module-desc {
        font-family: var(--font-sans);
        font-size: 10.5px;
        color: var(--ink-3);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .pv-module-arrow {
        color: var(--ink-4);
        flex-shrink: 0;
        transition: transform 0.15s;
      }

      .pv-module:hover .pv-module-arrow {
        color: var(--highlight);
        transform: translate(2px, -2px);
      }

      /* P3: AI mode toggle */
      .pv-aimode {
        background: var(--paper-elev);
        border: 0.5px solid var(--line);
        border-radius: 12px;
        padding: 0.8rem 0.85rem;
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
      }

      .pv-aimode-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-family: var(--font-mono);
        font-size: 9px;
        color: var(--ink-4);
        letter-spacing: 0.12em;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .pv-aimode-header > span {
        white-space: nowrap;
      }

      .pv-aimode-options {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }

      .pv-aimode-option {
        display: flex;
        align-items: flex-start;
        gap: 0.55rem;
        padding: 0.5rem 0.55rem;
        border: 0.5px solid var(--line);
        border-radius: 7px;
        background: var(--paper);
      }

      .pv-aimode-option.active {
        background: var(--highlight-soft);
        border-color: color-mix(in srgb, var(--highlight) 35%, transparent);
      }

      .pv-aimode-option.muted {
        opacity: 0.65;
      }

      .pv-aimode-radio {
        width: 12px;
        height: 12px;
        border: 1px solid var(--ink-4);
        border-radius: 50%;
        flex-shrink: 0;
        margin-top: 1px;
        position: relative;
      }

      .pv-aimode-option.active .pv-aimode-radio {
        border-color: var(--highlight);
      }

      .pv-aimode-option.active .pv-aimode-radio::after {
        content: "";
        position: absolute;
        inset: 2px;
        background: var(--highlight);
        border-radius: 50%;
      }

      .pv-aimode-text {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 1px;
        min-width: 0;
      }

      .pv-aimode-name {
        font-family: var(--font-sans);
        font-weight: 500;
        font-size: 12px;
        color: var(--ink);
      }

      .pv-aimode-meta {
        font-family: var(--font-mono);
        font-size: 9.5px;
        color: var(--ink-4);
        letter-spacing: 0.02em;
      }

      .pv-aimode-option.active .pv-aimode-meta {
        color: var(--highlight);
      }

      /* P1: Relation picker */
      .pv-picker {
        background: var(--paper-elev);
        border: 0.5px solid var(--line);
        border-radius: 12px;
        padding: 0.95rem 0.9rem;
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
      }

      .pv-picker-edge {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
      }

      .pv-picker-node {
        font-family: var(--font-serif);
        font-weight: 500;
        font-size: 13px;
        color: var(--ink);
        border-bottom: 0.8px solid var(--ink);
        padding-bottom: 1px;
        font-optical-sizing: auto;
      }

      .pv-picker-arrow {
        color: var(--cat-color);
        font-size: 14px;
      }

      .pv-picker-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
        justify-content: center;
      }

      .pv-picker-chips .relation-chip:not(.selected) {
        opacity: 0.55;
      }

      /* P2: Review card */
      .pv-review {
        background: var(--paper-elev);
        border: 0.5px solid var(--line);
        border-radius: 12px;
        padding: 0.95rem 0.9rem;
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
      }

      .pv-review-top {
        display: flex;
        justify-content: flex-start;
      }

      .pv-review-due {
        font-family: var(--font-mono);
        font-size: 9px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--highlight);
        background: var(--highlight-soft);
        border: 0.5px solid
          color-mix(in srgb, var(--highlight) 25%, transparent);
        border-radius: 999px;
        padding: 0.15rem 0.5rem;
      }

      .pv-review-concept {
        font-family: var(--font-serif);
        font-weight: 500;
        font-size: 1.3rem;
        letter-spacing: -0.01em;
        color: var(--ink);
        text-align: center;
        padding: 0.3rem 0;
        font-optical-sizing: auto;
      }

      .pv-review-ratings {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0.35rem;
      }

      .pv-review-btn {
        font-family: var(--font-sans);
        font-size: 10.5px;
        font-weight: 500;
        text-align: center;
        padding: 0.4rem 0.2rem;
        border-radius: 6px;
        border: 0.5px solid var(--line-strong);
        color: var(--ink-2);
        background: var(--paper);
        white-space: nowrap;
      }

      .pv-review-btn.again {
        color: var(--conf-1);
        border-color: color-mix(in srgb, var(--conf-1) 35%, transparent);
        background: color-mix(in srgb, var(--conf-1) 8%, var(--paper));
      }

      .pv-review-btn.hard {
        color: var(--conf-2);
        border-color: color-mix(in srgb, var(--conf-2) 35%, transparent);
        background: color-mix(in srgb, var(--conf-2) 8%, var(--paper));
      }

      .pv-review-btn.good {
        color: var(--conf-3);
        border-color: color-mix(in srgb, var(--conf-3) 35%, transparent);
        background: color-mix(in srgb, var(--conf-3) 8%, var(--paper));
      }

      .pv-review-btn.easy {
        color: var(--conf-4);
        border-color: color-mix(in srgb, var(--conf-4) 35%, transparent);
        background: color-mix(in srgb, var(--conf-4) 8%, var(--paper));
      }

      /* ── Socratic mentor (preview) ──────────── */
      .mentor-inner {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 2.5rem;
        align-items: center;
      }

      .mentor-badge {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.62rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--ink-4);
        padding: 0.2rem 0.55rem;
        border-radius: 999px;
        border: 0.5px solid var(--line-strong);
        margin-bottom: 0.9rem;
      }

      .mentor-heading {
        font-family: var(--font-serif);
        font-weight: 500;
        font-size: 1.55rem;
        letter-spacing: -0.01em;
        color: var(--ink);
        margin-bottom: 0.55rem;
        font-optical-sizing: auto;
      }

      .mentor-body {
        color: var(--ink-2);
        font-size: 1rem;
        line-height: 1.65;
        max-width: 460px;
      }

      .mentor-body :global(em) {
        font-style: italic;
        color: var(--highlight);
      }

      /* ── Edge vocabulary ────────────────────── */
      .relation-intro {
        font-size: 1rem;
        color: var(--ink-2);
        line-height: 1.7;
        margin-bottom: 2rem;
        max-width: 720px;
      }

      .relation-intro :global(em) {
        font-style: italic;
        color: var(--highlight);
      }

      .relation-row {
        display: grid;
        grid-template-columns: 175px 220px 1fr;
        gap: 1.5rem;
        align-items: center;
        padding: 1.4rem 0;
        border-bottom: 1px solid var(--line);
      }

      .relation-row:first-child {
        border-top: 1px solid var(--line);
      }

      .relation-cat {
        padding-left: 1rem;
        border-left: 2px solid var(--cat-color);
      }

      .relation-cat-name {
        display: block;
        font-family: var(--font-serif);
        font-weight: 500;
        font-size: 1rem;
        color: var(--ink);
        font-optical-sizing: auto;
      }

      .relation-cat-q {
        display: block;
        font-size: 0.78rem;
        color: var(--ink-4);
        margin-top: 0.2rem;
      }

      .relation-mini-svg {
        display: block;
        width: 100%;
        max-width: 220px;
        height: auto;
      }

      .rm-edge {
        stroke-width: 1.6;
        stroke-linecap: round;
        fill: none;
      }

      .rm-node-text {
        font-family: "Fraunces", Georgia, serif;
        font-weight: 500;
        font-size: 11px;
        letter-spacing: -0.005em;
        fill: var(--ink);
        text-anchor: middle;
        font-optical-sizing: auto;
      }

      .rm-node-underline {
        stroke: var(--ink);
        stroke-width: 0.6;
        opacity: 0.5;
      }

      .rm-edge-label {
        font-family: var(--font-mono);
        font-size: 8.5px;
        font-weight: 500;
        text-anchor: middle;
        letter-spacing: 0.04em;
      }

      .relation-types {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        align-items: center;
      }

      .relation-chip {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        padding: 0.2em 0.55em;
        border-radius: 4px;
        color: var(--cat-color);
        background: color-mix(in srgb, var(--cat-color) 8%, var(--paper));
        border: 1px solid color-mix(in srgb, var(--cat-color) 20%, transparent);
        white-space: nowrap;
      }

      .relation-chip.selected {
        color: var(--paper);
        background: var(--cat-color);
        border-color: var(--cat-color);
      }

      .relation-cta {
        text-align: right;
        margin-top: 1.5rem;
        font-size: 0.875rem;
        color: var(--ink-3);
      }

      .relation-cta a {
        color: var(--highlight);
        border-bottom: 1px solid currentColor;
      }

      /* ── Credo + final CTA ──────────────────── */
      .credo {
        max-width: 720px;
        margin: 7rem auto 3rem;
        padding: 0 2rem;
        text-align: center;
      }

      .credo-rule {
        width: 40px;
        height: 1px;
        background: var(--highlight);
        margin: 0 auto 2.5rem;
      }
      .credo > p + .credo-rule {
        margin: 2.5rem auto 0;
      }

      .credo-tail {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin-top: 2.5rem;
      }

      .credo p {
        font-family: var(--font-serif);
        font-weight: 400;
        font-size: clamp(1.4rem, 3.5vw, 2.25rem);
        line-height: 1.5;
        letter-spacing: -0.01em;
        color: var(--ink);
        font-optical-sizing: auto;
      }

      .credo p em {
        font-style: italic;
        color: var(--highlight);
        font-weight: 500;
      }

      .credo-cta {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
      }

      /* ── Footer ─────────────────────────────── */
      footer {
        border-top: 1px solid var(--line);
        max-width: 1080px;
        margin: 5rem auto 0;
        padding: 2.5rem 2rem 3rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--ink-4);
        letter-spacing: 0.02em;
      }

      .footer-links {
        display: flex;
        gap: 1.5rem;
      }
      .footer-links a:hover {
        color: var(--ink-2);
      }

      /* ── Responsive ─────────────────────────── */
      @media (max-width: 860px) {
        .principle {
          grid-template-columns: 1fr;
          gap: 0.6rem;
        }
        .principle-marker {
          padding-top: 0;
        }
        .principle-visual {
          padding-top: 0.8rem;
          max-width: 380px;
        }
        .mentor-inner {
          grid-template-columns: 1fr;
          gap: 1.5rem;
        }
        .mentor-visual {
          max-width: 380px;
        }
      }

      @media (max-width: 660px) {
        header {
          padding: 1.25rem 1.25rem;
        }
        .header-nav {
          gap: 0.8rem;
        }
        .header-nav a {
          font-size: 0.82rem;
        }

        .hero {
          padding: 0 1.25rem;
          margin-top: 2.5rem;
        }
        .hero-graph-wrap {
          padding: 0;
          margin-top: 3.5rem;
        }

        .section {
          padding: 0 1.25rem;
        }

        .relation-row {
          grid-template-columns: 1fr;
          gap: 0.9rem;
        }
        .relation-mini-svg {
          max-width: 280px;
        }

        .relation-cta {
          text-align: left;
        }

        footer {
          flex-direction: column;
          gap: 1rem;
          text-align: center;
          padding: 2rem 1.25rem;
        }

        .credo {
          padding: 0 1.25rem;
          margin-top: 5rem;
        }

        .credo-tail {
          min-height: clamp(9rem, 28vh, 22rem);
          margin-top: 2rem;
        }
      }

      @media (max-width: 480px) {
        .hero-graph-meta {
          display: none;
        }

        .hero-graph-socrates {
          width: 40px;
          height: 40px;
          right: 8px;
          bottom: 8px;
        }
      }

      /* ── Reduced motion ─────────────────────── */
      @media (prefers-reduced-motion: reduce) {
        .hero-graph-socrates::before {
          animation: none;
        }
      }
    </style>
    <style is:global>
      @keyframes tw-blink {
        50% {
          opacity: 0;
        }
      }

      .tw-cursor {
        display: inline-block;
        width: 2px;
        min-height: 0.85em;
        height: 0.85em;
        background: var(--ink);
        vertical-align: -0.05em;
        margin-left: 2px;
        animation: tw-blink 0.55s steps(1) infinite;
      }

      .hero-eyebrow .tw-cursor {
        background: var(--ink-3);
      }

      .tw-cursor.tw-cursor--done {
        visibility: hidden;
      }

      @media (prefers-reduced-motion: reduce) {
        .tw-cursor {
          display: none;
        }
      }
    </style>
  </head>
