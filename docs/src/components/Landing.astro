          <div class="credo-cta">
            <a
              href="https://app.nesso.how"
              class="btn btn-primary"
              target="_blank"
              rel="noopener"
            >
              {t.credo.ctaPrimary}
              <span class="btn-arrow">→</span>
            </a>
            <a
              href="https://github.com/cedoor/nesso"
              class="btn btn-secondary"
              target="_blank"
              rel="noopener">{t.credo.ctaSecondary}</a
            >
          </div>
        </div>
      </section>
    </main>

    <footer>
      <span>{t.footer.copyright}</span>
      <div class="footer-links">
        <a href="/docs/introduction/">{t.footer.docs}</a>
        <a href="https://github.com/cedoor/nesso" target="_blank" rel="noopener"
          >{t.footer.github}</a
        >
        <a href="https://app.nesso.how" target="_blank" rel="noopener"
          >{t.footer.app}</a
        >
      </div>
    </footer>

    <script>
      (function () {
        if (
          window.matchMedia &&
          window.matchMedia("(prefers-reduced-motion: reduce)").matches
        )
          return;

        const eyebrowEl =
          document.querySelector<HTMLSpanElement>(".hero-eyebrow");
        if (!eyebrowEl) return;
        const eyebrow: HTMLSpanElement = eyebrowEl;

        const SPEED = 30;
        const PAUSE_AFTER_SEP = 420;
        const START_DELAY = 450;
        const text = eyebrow.dataset.typewriter ?? "";

        const cursor = document.createElement("span");
        cursor.className = "tw-cursor";

        eyebrow.textContent = "";
        eyebrow.appendChild(cursor);

        let plain: Text | null = null;
        let i = 0;
        function tick() {
          if (i >= text.length) {
            setTimeout(() => cursor.classList.add("tw-cursor--done"), 500);
            return;
          }
          if (!plain) {
            plain = document.createTextNode("");
            eyebrow.insertBefore(plain, cursor);
          }
          const ch = text[i++]!;
          plain.textContent += ch;
          setTimeout(tick, ch === "·" ? PAUSE_AFTER_SEP : SPEED);
        }
        setTimeout(tick, START_DELAY);
      })();
    </script>
  </body>
</html>
